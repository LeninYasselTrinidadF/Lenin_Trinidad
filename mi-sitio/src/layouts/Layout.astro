---
import '../styles/global.css';

interface Props {
  title: string;
  page?: string;
}

const { title, page = '' } = Astro.props;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}`,           label: 'Inicio',    key: 'index'     },
  { href: `${base}apuntes/`,   label: 'Apuntes',   key: 'apuntes'   },
  { href: `${base}proyectos/`, label: 'Proyectos', key: 'proyectos' },
  { href: `${base}blog/`,      label: 'Blog',      key: 'blog'      },
  { href: `${base}sobre/`,     label: 'Sobre mí',  key: 'sobre'     },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Lenin Trinidad</title>
  <link rel="icon" type="image/png" href={`${base}imagenes/icon.png`} />
</head>
<body>
  <header id="site-header">
    <div class="header-container">
      <div class="header-title">
        <h1>Lenin Trinidad</h1>
      </div>
      <nav>
        {links.map(l => (
          <a href={l.href} class={page === l.key ? 'active' : ''}>
            {l.label}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <script>
    const hdr = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      hdr?.classList.toggle('scrolled', window.scrollY > 10);
      document.body.classList.toggle('header-scrolled', window.scrollY > 10);
    }, { passive: true });
  </script>
</body>
</html>
