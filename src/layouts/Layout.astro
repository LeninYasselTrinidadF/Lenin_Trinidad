---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

// Normalizar base: siempre con trailing slash
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}/`,           label: 'Inicio'    },
  { href: `${base}/apuntes/`,   label: 'Apuntes'   },
  { href: `${base}/proyectos/`, label: 'Proyectos' },
  { href: `${base}/blog/`,      label: 'Blog'      },
  { href: `${base}/sobre/`,     label: 'Sobre mí'  },
];

function isActive(href: string) {
  if (href === `${base}/`) return currentPath === href;
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Lenin Trinidad</title>
  <link rel="icon" type="image/png" href={`${base}/imagenes/icon.png`} />
</head>
<body>
  <header id="site-header">
    <div class="header-container">
      <div class="header-title">
        <h1>Lenin Trinidad</h1>
      </div>
      <nav>
        {links.map(l => (
          <a href={l.href} class={isActive(l.href) ? 'active' : ''}>
            {l.label}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

  <script>
    const hdr = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      hdr?.classList.toggle('scrolled', window.scrollY > 10);
      document.body.classList.toggle('header-scrolled', window.scrollY > 10);
    }, { passive: true });
  </script>
</body>
</html>