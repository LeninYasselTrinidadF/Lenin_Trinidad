---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const entradas = await getCollection('blog');
entradas.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout
  title="Blog"
  description="Entradas sobre matemáticas, sistemas dinámicos y experiencias académicas."
>
  <h2>Blog</h2>

  {entradas.map(e => (
    <article class="project">
      <h3>
        {e.data.title}
        <span class="project-status status-completed">{e.data.date}</span>
      </h3>
      <p>{e.data.description}</p>
      {e.data.tags && (
        <div class="project-tags">
          {e.data.tags.map((tag: string) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
      )}
      <p><a class="btn" href={`${base}/blog/${e.id}/`}>Leer más</a></p>
    </article>
  ))}
</Layout>
